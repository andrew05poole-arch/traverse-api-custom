@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model ApiLogin

<h2 class="title">Login</h2>

@using (Html.BeginForm("Login", "Home", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)
    <fieldset>
        <div class="form-group">
            @Html.Label("Email Address")
            <div>
                @Html.EditorFor(model => model.EmailAddress, new { @style = "width:100%;", htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.EmailAddress)
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Password")
            <div>
                @Html.EditorFor(model => model.Password, new { @style = "width:100%;", htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Password)
            </div>
        </div>

        <div class="form-group">
            <p>
                <input type="submit" value="Sign On" class="btn btn-default co" />
            </p>
        </div>
    </fieldset>

}