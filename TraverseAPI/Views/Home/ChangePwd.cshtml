@{
                /**/

                Layout = "~/Views/Shared/_Layout.cshtml";
}

@model ApiChangePassword

@using (Html.BeginForm("ChangePwd", "Home", FormMethod.Post))
{
    <h2 class="title">Change Password</h2>

    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <fieldset>
        <div class="form-group">
            @Html.Label("Current Password")
            <div>
                @Html.EditorFor(model => model.OldPassword, new { @style = "width:100%;", htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.OldPassword)
            </div>
        </div>

        <div class="form-group">
            @Html.Label("New Password")
            <div>
                @Html.EditorFor(model => model.Password, new { @style = "width:100%;", htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Password)
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Confirm Password")
            <div>
                @Html.EditorFor(model => model.ConfirmPassword, new { @style = "width:100%;", htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.ConfirmPassword)
            </div>
        </div>

        <div class="form-group">
            <p>
                <input type="submit" value="Change Password" class="btn btn-default co" />
            </p>
        </div>
    </fieldset>
}